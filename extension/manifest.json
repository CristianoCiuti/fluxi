{
  "manifest_version": 3,
  "name": "Fluxi Controller",
  "version": "1.0.0",
  "description": "Controlla Fluxi — invia URL al display remoto in tempo reale",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Fluxi Controller"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
